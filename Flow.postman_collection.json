      "name": "FD_Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsondata=pm.response.json();\r",
              "const token=jsondata.data.token;\r",
              "const schema = {\r",
              "  \r",
              "  \"title\": \"Generated Schema\",\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"message\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"data\": {\r",
              "      \"type\": \"object\",\r",
              "      \"properties\": {\r",
              "        \"token\": {\r",
              "          \"type\": \"string\"\r",
              "        }\r",
              "      },\r",
              "      \"required\": [\r",
              "        \"token\"\r",
              "      ]\r",
              "    }\r",
              "  },\r",
              "  \"required\": [\r",
              "    \"message\",\r",
              "    \"data\"\r",
              "  ]\r",
              "}\r",
              "pm.collectionVariables.set(\"token\", token);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200)\r",
              "\r",
              "})\r",
              "\r",
              "pm.test(\"Message should be 'Success'\", function () {\r",
              "    pm.expect(jsondata.message).to.eql(\"Success\")\r",
              "\r",
              "})\r",
              "\r",
              "pm.test(\"Token should be a valid JWT (3 parts)\",function()\r",
              "{\r",
              "    pm.expect(token.split('.').length).to.eql(3)\r",
              "})\r",
              "pm.test(\"Validate JSON Schema for Response\",function()\r",
              "{\r",
              "    pm.response.to.have.jsonSchema(schema)\r",
              "})\r",
              "pm.test(\"Responsetime to be below 150\",function()\r",
              "{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(160)\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
